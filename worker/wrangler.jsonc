{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "envpact-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "mcp.envpact.oriz.in",
      "custom_domain": true
    }
  ]
}
