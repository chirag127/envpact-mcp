# MCPB build outputs — regenerated by `npm run build:mcpb`.
# We commit manifest.json, icon.png, README.md inside mcpb/ but
# exclude the bundled server entry and the package.json copy.
mcpb/server/
mcpb/package.json

# Defense-in-depth: vault-shaped files should never appear here.
# The only legitimate location is ~/.envpact/secrets/.
secrets.json
age.key
*.age
*.pem
*.key
!**/lib/key.js
!**/lib/key.ts
